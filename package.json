    "@codemirror/state": "^6.4.1",
    "@tanstack/react-query": "^5.101.0",
    "@uiw/react-codemirror": "^4.23.6",
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.13",
    "dbgate-query-splitter": "^4.12.0",
    "express": "^4.22.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
