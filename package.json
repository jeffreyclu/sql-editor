  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "concurrently -n server,web -c blue,green \"tsx watch src/index.ts\" \"npm:dev:web\"",
    "build": "vite build",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --project server",
    "test:web": "vitest run --project web"
  },
